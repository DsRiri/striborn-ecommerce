{% extends 'base.html.twig' %}

{% block title %}Administration - Stubborn{% endblock %}

{% block body %}
    <h1>Administration des produits</h1>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Prix</th>
                <th>Stock</th>
                <th>En vedette</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for product in products %}
                <tr>
                    <td>{{ product.id }}</td>
                    <td>{{ product.name }}</td>
                    <td>{{ product.price|number_format(2, ',', ' ') }} €</td>
                    <td>{{ product.stock }}</td>
                    <td>{{ product.isFeatured ? 'Oui' : 'Non' }}</td>
                    <td>
                        <a href="{{ path('app_admin_product_delete', {id: product.id}) }}" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce produit ?')">Supprimer</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}