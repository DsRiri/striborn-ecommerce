{% extends 'base.html.twig' %}

{% block title %}Administration - Stubborn{% endblock %}

{% block body %}
    <h1 class="mb-4">Back-Office</h1>

    <!-- Formulaire AJOUTER -->
    <div class="card mb-4">
        <div class="card-header">
            <h3>Ajouter un produit</h3>
        </div>
        <div class="card-body">
            <form method="POST" action="{{ path('app_admin_product_add') }}" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-3 mb-2">
                        <input type="text" name="name" placeholder="Nom" class="form-control" required>
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="number" name="price" placeholder="Prix" class="form-control" step="0.01" required>
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="number" name="stock" placeholder="Stock" class="form-control" required>
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="file" name="image" class="form-control">
                    </div>
                    <div class="col-md-2 mb-2">
                        <input type="checkbox" name="isFeatured" value="1"> Mettre en avant
                    </div>
                    <div class="col-md-1 mb-2">
                        <button type="submit" class="btn btn-success">AJOUTER</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Liste des produits -->
    <div class="card">
        <div class="card-header">
            <h3>Produits existants</h3>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <th>Stock</th>
                        <th>En vedette</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for product in products %}
                        <tr>
                            <td>
                                <img src="{{ asset('uploads/' ~ product.image) }}" alt="{{ product.name }}" style="width:50px;height:50px;object-fit:cover;">
                            </td>
                            <td>{{ product.name }}</td>
                            <td>{{ product.price|number_format(2, ',', ' ') }} €</td>
                            <td>{{ product.stock }}</td>
                            <td>{{ product.isFeatured ? 'Oui' : 'Non' }}</td>
                            <td>
                                <a href="{{ path('app_admin_product_delete', {id: product.id}) }}" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce produit ?')">SUPPRIMER</a>
                                <a href="{{ path('app_admin_product_edit', {id: product.id}) }}" class="btn btn-warning btn-sm">MODIFIER</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}