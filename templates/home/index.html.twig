{% extends 'base.html.twig' %}

{% block title %}Accueil - Stubborn{% endblock %}

{% block body %}
    <div class="jumbotron text-center">
        <h1>Bienvenue chez Stubborn</h1>
        <p class="lead">Don't compromise on your look</p>
        <p>Piccadilly Circus, London W1J 0DA, Royaume-Uni</p>
        <hr class="my-4">
    </div>

    <h2>Nos produits en vedette</h2>
    <div class="row">
        {% for product in featuredProducts %}
            <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
                <div class="card h-100">
                    <img src="{{ asset('uploads/' ~ product.image) }}" class="card-img-top" alt="{{ product.name }}" style="height:250px;object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text">{{ product.price|number_format(2, ',', ' ') }} €</p>
                        {% if app.user %}
                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn btn-primary">Voir</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}